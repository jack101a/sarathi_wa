# Sarathi Bot local Docker env example
# Copy to .env and fill every value before running docker compose.

TZ=Asia/Kolkata
NODE_ENV=production
APP_ENV=production
CONFIG_PATH=.
PORT=3000
PG_BIND=127.0.0.1
PG_HOST_PORT=5432
REDIS_BIND=127.0.0.1
REDIS_HOST_PORT=6379
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# PostgreSQL - single source of truth
PGHOST=postgres
PGPORT=5432
PGDATABASE=sarathi
PGUSER=sarathi
PGPASSWORD=change_this_postgres_password

# Redis - single source of truth
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password

# Admin dashboard
ADMIN_USERNAME=admin
ADMIN_TOKEN=change_this_admin_token
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=

# WhatsApp gateway
INSTANCE_ID=wa-primary
INSTANCE_ROLE=primary
REQUIRE_CHAT_FRONTEND=true
SESSION_NAME=default-session
WHATSAPP_PHONE_NUMBER=
AUTHORIZED_USERS=
AUTHORIZED_GROUPS=
ADMIN_USERS=

# Telegram gateway/admin testing
TELEGRAM_BOT_TOKEN=
AUTHORIZED_TG_USERS=
AUTHORIZED_TG_GROUPS=
TELEGRAM_NOTIFY_CHAT_IDS=

# Razorpay wallet top-up
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_QR_NAME=Sarathi Bot

# Notifications
DISCORD_WEBHOOK_URL=

# Scheduler / backup
AUTO_TRACK_CRON=0 10-22/3 * * *
VAHAN_TRACK_CRON=0 10-22/3 * * *
AUTO_TRACK_UPDATE_CHAT_ID=
VAHAN_TRACK_UPDATE_CHAT_ID=
AUTO_CLOUD_BACKUP_ENABLED=true
BACKUP_HEALTH_MAX_AGE_HOURS=8

# Worker concurrency
API_CONCURRENCY=8
SESSION_POOL_SIZE=3
BROWSER_ENGINE=puppeteer
BROWSER_CONCURRENCY=2
MAX_BROWSER_PAGES=5

# Browser runtime
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_HEADLESS=true
PUPPETEER_DISABLE_SANDBOX=true
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage

# AI parsing
AI_PARSING_ENABLED=false
LITELLM_API_BASE=
LITELLM_API_KEY=
LITELLM_MODEL=gemini/gemini-1.5-flash

# Logging
LOG_LEVEL=info
