CONFIG_PATH=.
APP_ENV=production
DEBUG=false
PORT=3000

# At least one frontend is required
SESSION_NAME=default-session
WHATSAPP_PHONE_NUMBER=
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFY_CHAT_IDS=

# Access control
AUTHORIZED_USERS=
AUTHORIZED_GROUPS=
AUTHORIZED_TG_USERS=
AUTHORIZED_TG_GROUPS=
ADMIN_USERS=

# Notifications
AUTO_TRACK_UPDATE_CHAT_ID=
VAHAN_TRACK_UPDATE_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Schedulers
AUTO_TRACK_CRON=0 10-22/3 * * *
VAHAN_TRACK_CRON=0 10-22/3 * * *

# Postgres & Redis Config
DATABASE_URL=
REDIS_URL=
PG_PASSWORD=
REDIS_PASSWORD=

# Admin dashboard
ADMIN_TOKEN=change_this_strong_token
ADMIN_USERNAME=admin

# Optional Razorpay auto top-up
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_QR_NAME=Sarathi Bot
