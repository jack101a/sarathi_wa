# ══════════════════════════════════════════════════════════════════════════════
#  Sarathi Bot — Portainer Environment Variables
#  Branch: scaling-production
#
#  HOW TO USE:
#  Option A — Portainer UI:  Stack → Environment Variables → paste each line
#  Option B — Portainer .env: Upload this file as the stack env file
#
#  ⚠  REQUIRED fields are marked with [REQUIRED]
#  ✅  Fields with defaults are safe to leave unchanged for first deploy
# ══════════════════════════════════════════════════════════════════════════════


# ── Infrastructure ─────────────────────────────────────────────────────────────

# PostgreSQL password — change before first deploy [REQUIRED]
PG_PASSWORD=sarathi_strong_pass_change_me

# Redis password — change before first deploy [REQUIRED]
REDIS_PASSWORD=redis_strong_pass_change_me

# Path on host where persistent data is stored [REQUIRED]
# Example: /opt/sarathi or /home/ubuntu
CONFIG_PATH=/opt/sarathi


# ── WhatsApp ───────────────────────────────────────────────────────────────────

# WhatsApp session name (used for .wwebjs_auth directory)
SESSION_NAME=default-session

# The WhatsApp number this bot uses (digits only, with country code, no +)
# Example: 919876543210
WHATSAPP_PHONE_NUMBER=

# Comma-separated WhatsApp JIDs allowed to use the bot [REQUIRED]
# Format: 919876543210@c.us,919876543211@c.us
AUTHORIZED_USERS=

# Comma-separated WhatsApp Group JIDs allowed to use the bot (optional)
# Format: 120363XXXXXXXX@g.us
AUTHORIZED_GROUPS=

# Comma-separated WhatsApp JIDs with admin privileges [REQUIRED]
# Same format as AUTHORIZED_USERS
ADMIN_USERS=


# ── Telegram ───────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather [REQUIRED if using Telegram bot]
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot
AUTHORIZED_TG_USERS=

# Comma-separated Telegram group/chat IDs allowed to use the bot
AUTHORIZED_TG_GROUPS=

# Comma-separated Telegram chat IDs to receive system notifications
TELEGRAM_NOTIFY_CHAT_IDS=

# Telegram chat IDs for auto-track update notifications
AUTO_TRACK_UPDATE_CHAT_ID=
VAHAN_TRACK_UPDATE_CHAT_ID=


# ── Admin Dashboard ─────────────────────────────────────────────────────────────

# Admin dashboard login username
ADMIN_USERNAME=admin

# Admin dashboard login password/token [REQUIRED — change this!]
ADMIN_TOKEN=changeme_set_a_real_secret_here

# Port the admin API listens on (exposed via Portainer port mapping)
PORT=3000


# ── Cron Schedules ─────────────────────────────────────────────────────────────

# How often to auto-refresh DL tracking (default: every 3 hours between 10am-10pm)
AUTO_TRACK_CRON=0 10-22/3 * * *

# How often to auto-refresh Vahan/RC tracking
VAHAN_TRACK_CRON=0 10-22/3 * * *


# ── Payment / UPI ──────────────────────────────────────────────────────────────

# UPI ID displayed when user types "topup" (fallback if Razorpay not configured)
UPI_ID=sarathi@upi

# Name displayed with UPI ID
UPI_NAME=Sarathi Bot


# ── Razorpay (Auto Payment — optional but recommended) ─────────────────────────
# Get keys from: https://dashboard.razorpay.com → Settings → API Keys
# If NOT set → falls back to manual UPI + UTR flow

# Razorpay Key ID (starts with rzp_live_ for production)
RAZORPAY_KEY_ID=

# Razorpay Key Secret
RAZORPAY_KEY_SECRET=

# Webhook secret — set in Razorpay Dashboard → Settings → Webhooks
# Webhook URL to add in Razorpay: https://YOUR_VPS_IP:3000/admin/api/payments/razorpay/webhook
# Events to enable: payment.captured, qr_code.credited
RAZORPAY_WEBHOOK_SECRET=


# ── Notifications ──────────────────────────────────────────────────────────────

# Discord webhook URL for admin alerts (optional)
DISCORD_WEBHOOK_URL=


# ── Browser / Puppeteer ────────────────────────────────────────────────────────

# Browser engine to use: puppeteer (default) or playwright
BROWSER_ENGINE=puppeteer

# Max concurrent browser sessions in worker-browser
BROWSER_CONCURRENCY=2

# Max browser pages open at once
MAX_BROWSER_PAGES=5


# ── Worker / API Concurrency ───────────────────────────────────────────────────

# Max concurrent API jobs (tracking, forms, etc.)
API_CONCURRENCY=8

# WhatsApp session pool size (to bypass 50-req-per-session limit)
SESSION_POOL_SIZE=3


# ── AI Parsing (optional) ──────────────────────────────────────────────────────

# Enable AI-powered receipt/status parsing
AI_PARSING_ENABLED=false

# LiteLLM proxy base URL
LITELLM_API_BASE=

# LiteLLM API key
LITELLM_API_KEY=

# Model to use (default: Gemini Flash)
LITELLM_MODEL=gemini/gemini-1.5-flash


# ── Logging ────────────────────────────────────────────────────────────────────

# Log level: debug | info | warn | error
LOG_LEVEL=info


# ── App Environment ────────────────────────────────────────────────────────────

APP_ENV=production
DEBUG=false
