# Sarathi Bot Portainer env example
# Put these values into Portainer Stack environment variables.
# No direct DATABASE_URL/REDIS_URL is used here. Keep PG* and REDIS_* as the single source of truth.

TZ=Asia/Kolkata
NODE_ENV=production
APP_ENV=production
DEBUG=false
LOG_LEVEL=info
IMAGE_TAG=latest
CONFIG_PATH=/opt/sarathi
CONFIG_FILE=data/config.yml
PORT=3000

# PostgreSQL - one password source
PGHOST=postgres
PGPORT=5432
PGDATABASE=sarathi
PGUSER=sarathi
PGPASSWORD=change_this_postgres_password

# Redis - one password source
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password

# Admin dashboard
ADMIN_USERNAME=admin
ADMIN_TOKEN=change_this_admin_token
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=

# WhatsApp user interface
REQUIRE_CHAT_FRONTEND=true
WHATSAPP_PHONE_NUMBER=
AUTHORIZED_USERS=
AUTHORIZED_GROUPS=
ADMIN_USERS=

# Telegram admin/testing gateway
TELEGRAM_BOT_TOKEN=
TG_TOKEN=
TELEGRAM_POLLING=true
AUTHORIZED_TG_USERS=
AUTHORIZED_TG_GROUPS=
AUTHORIZED_TG_ADMINS=
TELEGRAM_NOTIFY_CHAT_IDS=

# Razorpay wallet top-up
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_QR_NAME=Sarathi Bot

# Notifications
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK=

# Scheduler / backup
AUTO_TRACK_CRON=0 10-22/3 * * *
VAHAN_TRACK_CRON=0 10-22/3 * * *
AUTO_TRACK_UPDATE_CHAT_ID=
VAHAN_TRACK_UPDATE_CHAT_ID=
AUTO_CLOUD_BACKUP_ENABLED=true
BACKUP_HEALTH_MAX_AGE_HOURS=8
DAILY_FILLING_ENABLED=false

# Queue / worker tuning
API_QUEUE_NAME=sarathi-api-jobs
BROWSER_QUEUE_NAME=sarathi-browser-jobs
API_CONCURRENCY=8
SESSION_POOL_SIZE=3
BROWSER_ENGINE=puppeteer
BROWSER_CONCURRENCY=2
MAX_BROWSER_PAGES=5
BROWSER_DELAY_MS=3000
BROWSER_MAX_RETRIES=2
BROWSER_BACKOFF_MS=5000

# Browser runtime
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_HEADLESS=true
PUPPETEER_DISABLE_SANDBOX=true
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage

# Runtime storage
AUTO_TRACK_STORE_FILE=data/tracked_applications.json
VAHAN_TRACK_STORE_FILE=data/vahan_tracked_applications.json
TEMP_DIR=data/tmp

# Vahan captcha
VAHAN_CAPTCHA_MODEL_PATH=models/godmode_solver.onnx
VAHAN_CAPTCHA_AUTO_SOLVE=true
VAHAN_CAPTCHA_MAX_ATTEMPTS=8
VAHAN_CAPTCHA_RETRY_MIN_MS=3000
VAHAN_CAPTCHA_RETRY_MAX_MS=5000

# AI parsing
AI_PARSING_ENABLED=false
LITELLM_API_BASE=
LITELLM_API_KEY=
LITELLM_MODEL=gemini/gemini-1.5-flash
