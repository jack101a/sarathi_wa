# Minimal operational env

APP_ENV=development
DEBUG=false
PORT=3000
DAILY_FILLING_ENABLED=false

# Mounted YAML config file
CONFIG_FILE=data/config.yml

# Frontends
SESSION_NAME=default-session
WHATSAPP_PHONE_NUMBER=
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFY_CHAT_IDS=

# Access control
AUTHORIZED_USERS=
AUTHORIZED_GROUPS=
AUTHORIZED_TG_USERS=
AUTHORIZED_TG_GROUPS=
ADMIN_USERS=
AUTHORIZED_TG_ADMINS=

# Auth storage
AUTHZ_DB_PATH=data/authz.sqlite

# Notifications
AUTO_TRACK_UPDATE_CHAT_ID=
VAHAN_TRACK_UPDATE_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Schedulers
AUTO_TRACK_CRON=0 10-22/3 * * *
VAHAN_TRACK_CRON=0 10-22/3 * * *

# Optional runtime overrides
AUTO_TRACK_STORE_FILE=data/tracked_applications.json
VAHAN_TRACK_STORE_FILE=data/vahan_tracked_applications.json
TEMP_DIR=data/tmp

# Optional Vahan overrides
VAHAN_CAPTCHA_MODEL_PATH=godmode_solver.onnx
VAHAN_CAPTCHA_AUTO_SOLVE=true
VAHAN_CAPTCHA_MAX_ATTEMPTS=8
VAHAN_CAPTCHA_RETRY_MIN_MS=3000
VAHAN_CAPTCHA_RETRY_MAX_MS=5000

# Optional Docker / Chromium overrides
PUPPETEER_HEADLESS=true
PUPPETEER_ARGS=
PUPPETEER_DISABLE_SANDBOX=false
PUPPETEER_EXECUTABLE_PATH=

# AI Parsing & Self-Learning via LiteLLM
AI_PARSING_ENABLED=false
LITELLM_API_BASE=http://localhost:4000/v1
LITELLM_API_KEY=
LITELLM_MODEL=gemini/gemini-1.5-flash

