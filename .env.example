# Runtime environment
# APP_ENV: Use `development` for local logs and `production` for deployment.
APP_ENV=development
DEBUG=false
PORT=3000

# WhatsApp client
# Session is persisted automatically by whatsapp-web.js LocalAuth in .wwebjs_auth/
# QR code is shown in terminal on first login.
SESSION_NAME=default-session
# Optional: use "Link with phone number" instead of scanning a QR on the server.
# Enter the phone number in international format without spaces or plus sign.
WHATSAPP_PHONE_NUMBER=

# Telegram bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFY_CHAT_IDS=

# HTTP client
# USER_AGENT: Outbound browser-like user agent for upstream requests.
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36
TIMEOUT_MS=60000

# Sarathi URLs (required)
HOME_URL=https://sarathi.parivahan.gov.in/sarathiservice/
STATUS_URL=https://sarathi.parivahan.gov.in/sarathiservice/applStatus.do
FORM_URL=https://sarathi.parivahan.gov.in/sarathiservice/form2pdfreport.do
ACK_URL=https://sarathi.parivahan.gov.in/sarathiservice/printAck.do

# Sarathi state settings (required)
STATE_ID=YOUR_STATE_ID
STATE_CODE=MH

# Session cache
SESSION_MAX_REQUESTS=50
SESSION_TTL_MS=600000

# Puppeteer runtime
# PUPPETEER_EXECUTABLE_PATH example (Docker): /usr/bin/google-chrome
PUPPETEER_HEADLESS=true
PUPPETEER_DISABLE_SANDBOX=false
PUPPETEER_EXECUTABLE_PATH=
# Comma-separated Chromium flags. Leave empty to use defaults from config.js.
PUPPETEER_ARGS=

# Optional local test values
TEST_APP_NO=
TEST_DOB=

# Optional alerts
DISCORD_WEBHOOK_URL=

# Auto-tracking
# Every 3 hours between 10:00 and 22:00 by default.
AUTO_TRACK_CRON=0 10-22/3 * * *
AUTO_TRACK_STORE_FILE=data/tracked_applications.json
AUTO_TRACK_UPDATE_CHAT_ID=

# Vahan auto-tracking
# Uses the same schedule style as Sarathi by default.
VAHAN_TRACK_CRON=0 10-22/3 * * *
VAHAN_TRACK_STORE_FILE=data/vahan_tracked_applications.json
VAHAN_TRACK_UPDATE_CHAT_ID=
VAHAN_CAPTCHA_AUTO_SOLVE=true
VAHAN_CAPTCHA_MODEL_PATH=godmode_solver.onnx
VAHAN_CAPTCHA_MAX_ATTEMPTS=8
VAHAN_CAPTCHA_RETRY_MIN_MS=3000
VAHAN_CAPTCHA_RETRY_MAX_MS=5000

# Admin users for restricted helper actions like `send chatid`
ADMIN_USERS=
