# Sarathi Bot full env example
# Copy to .env for local host runs, or use the Docker-specific examples for Compose/Portainer.
# Do not put real secrets in Git. Replace every change_this_* value before production.
# Database and Redis are intentionally configured with discrete variables, not DATABASE_URL/REDIS_URL.

# ─────────────────────────────────────────────────────────────────────────────
# App runtime
# ─────────────────────────────────────────────────────────────────────────────
TZ=Asia/Kolkata
NODE_ENV=production
APP_ENV=production
DEBUG=false
LOG_LEVEL=info
PORT=3000
CONFIG_PATH=.
CONFIG_FILE=data/config.yml
TEMP_DIR=data/tmp

# Optional overrides for config.example.yml. Leave blank to use config.yml values.
STATE_ID=
STATE_CODE=
HOME_URL=
STATUS_URL=
FORM_URL=
ACK_URL=
USER_AGENT=
TIMEOUT_MS=60000
SESSION_MAX_REQUESTS=50
SESSION_TTL_MS=600000

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL - single source of truth
# ─────────────────────────────────────────────────────────────────────────────
PGHOST=postgres
PGPORT=5432
PGDATABASE=sarathi
PGUSER=sarathi
PGPASSWORD=change_this_postgres_password
PG_BIND=127.0.0.1
PG_HOST_PORT=5432

# ─────────────────────────────────────────────────────────────────────────────
# Redis - single source of truth
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password
REDIS_BIND=127.0.0.1
REDIS_HOST_PORT=6379

# Queue names. Usually keep these unchanged unless separating environments.
API_QUEUE_NAME=sarathi-api-jobs
BROWSER_QUEUE_NAME=sarathi-browser-jobs

# ─────────────────────────────────────────────────────────────────────────────
# Admin dashboard
# ─────────────────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Browser dashboard login. Prefer ADMIN_PASSWORD_HASH for production.
ADMIN_PASSWORD=
# Optional SHA-256 hash format: sha256:<hex>. If set, ADMIN_PASSWORD is not needed.
ADMIN_PASSWORD_HASH=
# Legacy/API fallback token. Keep long and random; browser login uses password.
ADMIN_TOKEN=change_this_admin_token

# ─────────────────────────────────────────────────────────────────────────────
# WhatsApp user interface
# ─────────────────────────────────────────────────────────────────────────────
INSTANCE_ID=wa-primary
INSTANCE_ROLE=primary
SESSION_NAME=default-session
WHATSAPP_PHONE_NUMBER=
REQUIRE_CHAT_FRONTEND=true

# Comma-separated allow/admin lists. Prefer dashboard-managed users in production.
AUTHORIZED_USERS=
AUTHORIZED_GROUPS=
ADMIN_USERS=

# ─────────────────────────────────────────────────────────────────────────────
# Telegram admin/testing gateway
# ─────────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TG_TOKEN=
TELEGRAM_POLLING=true
TELEGRAM_NOTIFY_CHAT_IDS=
AUTHORIZED_TG_USERS=
AUTHORIZED_TG_GROUPS=
AUTHORIZED_TG_ADMINS=

# ─────────────────────────────────────────────────────────────────────────────
# Notifications
# ─────────────────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK=
AUTO_TRACK_UPDATE_CHAT_ID=
VAHAN_TRACK_UPDATE_CHAT_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Scheduler, tracking, backup
# ─────────────────────────────────────────────────────────────────────────────
AUTO_TRACK_CRON=0 10-22/3 * * *
VAHAN_TRACK_CRON=0 10-22/3 * * *
AUTO_TRACK_STORE_FILE=data/tracked_applications.json
VAHAN_TRACK_STORE_FILE=data/vahan_tracked_applications.json
AUTO_CLOUD_BACKUP_ENABLED=true
BACKUP_HEALTH_MAX_AGE_HOURS=8
DAILY_FILLING_ENABLED=false

# Cloud backup providers are configured from the admin dashboard and stored in PostgreSQL.
# Supported provider records: telegram, rclone, r2.
# rclone also needs its remote configured inside the container/environment where scheduler runs.

# ─────────────────────────────────────────────────────────────────────────────
# Browser and worker scaling
# ─────────────────────────────────────────────────────────────────────────────
API_CONCURRENCY=8
SESSION_POOL_SIZE=3
BROWSER_ENGINE=puppeteer
BROWSER_CONCURRENCY=2
MAX_BROWSER_PAGES=5
BROWSER_DELAY_MS=3000
BROWSER_MAX_RETRIES=2
BROWSER_BACKOFF_MS=5000

PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_HEADLESS=true
PUPPETEER_DISABLE_SANDBOX=true
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage

# ─────────────────────────────────────────────────────────────────────────────
# Vahan captcha/runtime
# ─────────────────────────────────────────────────────────────────────────────
VAHAN_CAPTCHA_MODEL_PATH=models/godmode_solver.onnx
VAHAN_CAPTCHA_AUTO_SOLVE=true
VAHAN_CAPTCHA_MAX_ATTEMPTS=8
VAHAN_CAPTCHA_RETRY_MIN_MS=3000
VAHAN_CAPTCHA_RETRY_MAX_MS=5000

# ─────────────────────────────────────────────────────────────────────────────
# AI parsing
# ─────────────────────────────────────────────────────────────────────────────
AI_PARSING_ENABLED=false
LITELLM_API_BASE=
LITELLM_API_KEY=
LITELLM_MODEL=gemini/gemini-1.5-flash

# ─────────────────────────────────────────────────────────────────────────────
# Razorpay wallet top-up
# ─────────────────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_QR_NAME=Sarathi Bot

# ─────────────────────────────────────────────────────────────────────────────
# Local Docker/Nginx ports
# ─────────────────────────────────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
IMAGE_TAG=latest

# ─────────────────────────────────────────────────────────────────────────────
# Legacy import utility only. Not used by production runtime.
# ─────────────────────────────────────────────────────────────────────────────
AUTHZ_DB_PATH=data/authz.sqlite
