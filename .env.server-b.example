# Sarathi Bot Server-B env example
# Server-B connects to Server-A PostgreSQL/Redis using discrete env variables only.
# No direct DATABASE_URL/REDIS_URL is used here.

TZ=Asia/Kolkata
NODE_ENV=production
APP_ENV=production
DEBUG=false
LOG_LEVEL=info
IMAGE_TAG=latest
CONFIG_PATH=/opt/sarathi
CONFIG_FILE=data/config.yml

# Server-A connection targets. Use WireGuard IP when available.
PGHOST=10.99.0.1
PGPORT=5432
PGDATABASE=sarathi
PGUSER=sarathi
PGPASSWORD=change_this_postgres_password

REDIS_HOST=10.99.0.1
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password

# Must match Server-A queue names.
API_QUEUE_NAME=sarathi-api-jobs
BROWSER_QUEUE_NAME=sarathi-browser-jobs

# WhatsApp gateway
REQUIRE_CHAT_FRONTEND=true
WHATSAPP_PHONE_NUMBER=
AUTHORIZED_USERS=
AUTHORIZED_GROUPS=
ADMIN_USERS=
TELEGRAM_BOT_TOKEN=

# Razorpay wallet top-up
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_QR_NAME=Sarathi Bot

# Notifications
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK=

# Worker tuning
API_CONCURRENCY=4
SESSION_POOL_SIZE=2
BROWSER_ENGINE=puppeteer
BROWSER_CONCURRENCY=2
MAX_BROWSER_PAGES=5
BROWSER_DELAY_MS=3000
BROWSER_MAX_RETRIES=2
BROWSER_BACKOFF_MS=5000

# AI parsing. Keep matching Server-A if enabled there.
AI_PARSING_ENABLED=false
LITELLM_API_BASE=
LITELLM_API_KEY=
LITELLM_MODEL=gemini/gemini-1.5-flash

# Browser runtime
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_HEADLESS=true
PUPPETEER_DISABLE_SANDBOX=true
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage
