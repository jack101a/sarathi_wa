# ══════════════════════════════════════════════════════════════════════════════
#  Sarathi Bot — Server B (Home Mini PC) Environment Variables
#
#  Copy this to .env on your home server and fill in the values.
#  Run: docker compose -f docker-compose.server-b.yml up -d
# ══════════════════════════════════════════════════════════════════════════════

# ── Oracle VPS (Server A) connection ──────────────────────────────────────────
# After WireGuard VPN is set up, use the TUNNEL IP (not the public IP).
# VPS tunnel IP is always 10.99.0.1 — never changes, never exposed publicly.
# See wireguard/setup-server-b.sh to set up the VPN first.
SERVER_A_IP=10.99.0.1

# Must match PG_PASSWORD set on Server A [REQUIRED]
PG_PASSWORD=

# Must match REDIS_PASSWORD set on Server A [REQUIRED]
REDIS_PASSWORD=

# ── Host path for data/auth on this machine ───────────────────────────────────
CONFIG_PATH=/opt/sarathi

# ── WhatsApp (same values as Server A) ───────────────────────────────────────
WHATSAPP_PHONE_NUMBER=
AUTHORIZED_USERS=
AUTHORIZED_GROUPS=
ADMIN_USERS=

# ── Razorpay Wallet Top-up ────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_QR_NAME=Sarathi Bot

# ── Notifications ─────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Browser worker ────────────────────────────────────────────────────────────
BROWSER_ENGINE=puppeteer
BROWSER_CONCURRENCY=2
MAX_BROWSER_PAGES=5

# ── Misc ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
