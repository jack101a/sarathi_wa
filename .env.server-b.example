# Sarathi Bot Server-B env example
# Server-B connects to Server-A PostgreSQL/Redis using discrete env variables only.

TZ=Asia/Kolkata
NODE_ENV=production
APP_ENV=production
IMAGE_TAG=latest
CONFIG_PATH=/opt/sarathi

# Server-A connection targets. Use WireGuard IP when available.
PGHOST=10.99.0.1
PGPORT=5432
PGDATABASE=sarathi
PGUSER=sarathi
PGPASSWORD=change_this_postgres_password

REDIS_HOST=10.99.0.1
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password

# WhatsApp gateway
REQUIRE_CHAT_FRONTEND=true
WHATSAPP_PHONE_NUMBER=
AUTHORIZED_USERS=
AUTHORIZED_GROUPS=
ADMIN_USERS=
TELEGRAM_BOT_TOKEN=

# Razorpay wallet top-up
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_QR_NAME=Sarathi Bot

# Notifications
DISCORD_WEBHOOK_URL=

# Browser worker
BROWSER_ENGINE=puppeteer
BROWSER_CONCURRENCY=2
MAX_BROWSER_PAGES=5
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_HEADLESS=true
PUPPETEER_DISABLE_SANDBOX=true
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage

# Logging
LOG_LEVEL=info
