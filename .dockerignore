# Node modules — never copy into the image (installed fresh by npm ci)
node_modules
frontend/node_modules

# Local development auth sessions and profiles (volume-mounted or unused)
.wwebjs_auth
.wwebjs_cache
firefox_profiles/
firefox_permanent_profile/
scratch/
trash/

# Local data directory (volume-mounted at runtime)
data/

# Build artifacts that are regenerated in the Docker stages
frontend/dist

# Git history and CI files (not needed in runtime image)
.git
.gitignore
.github

# Editor / OS noise
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/
debug_*.png
application_status.png
LL_*.pdf

# Local env file — secrets must come from docker-compose env, never baked in
.env
.env.*

# Testing
testing_ground/
*.test.js
*.spec.js

# Dev planning artifacts
implementation_plan.md
task.md
walkthrough.md

# Local development scripts (Windows-only, not needed in Linux container)
scripts/
